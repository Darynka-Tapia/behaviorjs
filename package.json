{
  "name": "behaviorjs",
  "version": "1.0.0",
  "description": "",
  "keywords": [
    "user-behavior-analysis", 
    "hci",
    "ux-analytics",
    "interaction-tracking",
    "frontend-monitoring"
  ],
  "license": "MIT",
  "author": "Darynka Tapia",
  "type": "module",
  "main": "./dist/index.cjs", 
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "directories": {
    "example": "examples"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Darynka-Tapia/behaviorjs.git"
  },
  "bugs": {
    "url": "https://github.com/Darynka-Tapia/behaviorjs/issues"
  },
  "homepage": "https://github.com/Darynka-Tapia/behaviorjs#readme",
  "scripts": {
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "build": "tsup src/index.ts --format cjs,esm --clean --dts",
    "lint": "tsc --noEmit",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
